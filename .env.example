APP_NAME=Afyalink
APP_ENV=local
APP_URL=https://www.afyalinks.org
API_URL=https://api.afyalinks.org
CORS_ALLOWED_ORIGINS=https://www.afyalinks.org
NEXT_PUBLIC_SITE_URL=https://www.afyalinks.org
NEXT_PUBLIC_AFYA_API_BASE=https://api.afyalinks.org

AFYALINK_DATASTORE=pgsql
DATABASE_URL=postgresql://afyalink:afyalink_dev_password@localhost:5432/afyalink
REDIS_URL=redis://localhost:6379

AFYALINK_SESSION_TTL_SECONDS=43200
AFYALINK_EMAIL_VERIFICATION_TTL_SECONDS=86400
AFYALINK_PASSWORD_RESET_TTL_SECONDS=3600
AFYALINK_MAX_UPLOAD_BYTES=8388608

AFYALINK_CREDENTIAL_STORAGE=local
AFYALINK_LOCAL_CREDENTIAL_ROOT=apps/api/storage/private/credentials
S3_BUCKET=afyalink-credentials
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=afyalink
S3_SECRET_ACCESS_KEY=afyalink_dev_password

MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_CALLBACK_URL=https://api.afyalinks.org/api/payments/mpesa/callback

MAIL_DRIVER=log
MAIL_FROM_ADDRESS=no-reply@afyalinks.org
MAIL_FROM_NAME=Afyalink
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls
PUBLIC_CONTACT_PHONE=+254711776391
PUBLIC_LOCATION=Hardy, Karen
SUPPORT_EMAIL=
PUBLIC_CONTACT_EMAIL=
ADMIN_EMAIL=
NOTIFICATION_WORKER_BATCH_SIZE=50
NOTIFICATION_WORKER_SCHEDULE=*/10 * * * *

AI_RECOMMENDATION_DRIVER=local
AI_PROVIDER=
AI_MODEL=
AI_API_KEY=
