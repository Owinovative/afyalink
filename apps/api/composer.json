{
  "name": "afyalink/api-foundation",
  "description": "Afyalink Milestone 1 domain foundation for credential intake, consent, payments, audit, and admin review.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.3"
  },
  "autoload": {
    "psr-4": {
      "Afyalink\\Core\\": "src/"
    }
  },
  "scripts": {
    "test": "php tests/run.php",
    "check": [
      "@php scripts/lint.php",
      "@php -l tests/run.php",
      "@test"
    ]
  },
  "config": {
    "sort-packages": true
  }
}
